runtime: nodejs22
env: standard

instance_class: F1

automatic_scaling:
  max_instances: 5

env_variables:
  NODE_ENV: "production"
  CLIENT_ORIGIN: "https://your-domain.com"
  COOKIE_SECURE: "true"
  COOKIE_SAME_SITE: "none"
  MONGODB_URI: "mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=your-app"
  JWT_SECRET: "your-jwt-secret-here"
  # Shared secret for the recurring-entries cron. Must match CRON_SECRET set on
  # the Cloudflare MCP worker (wrangler secret put CRON_SECRET).
  CRON_SECRET: "your-cron-secret-here"
  RESEND_API_KEY: "re_your_api_key_here"
  RESEND_FROM_EMAIL: "Your App <noreply@yourdomain.com>"
  # Secret required to create an additional business account via
  # POST /api/auth/signup. Leave this unset to keep account creation disabled:
  # the route 403s rather than falling open, so a missing value can never
  # silently expose public registration.
  SIGNUP_INVITE_CODE: "generate-a-long-random-string"
